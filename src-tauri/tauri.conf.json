{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "auto-installer",
  "version": "0.1.0",
  "identifier": "com.zilorn.auto-installer",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "auto-installer",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/app-icon-32x32.png",
      "icons/app-icon-128x128.png",
      "icons/app-icon-256x256.png",
      "icons/app-icon.icns",
      "icons/app-icon.ico"
    ]
  }
}
